{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Framework": {
    "Name": "Birko Framework",
    "Version": "1.0.0",
    "Environment": "Development"
  },
  "Data": {
    "DefaultStoreType": "Json",
    "ConnectionString": "./Data",
    "EnableChangeTracking": true
  },
  "Communication": {
    "WebSocket": {
      "Enabled": true,
      "Port": 8080
    },
    "Authentication": {
      "Enabled": false,
      "Tokens": []
    }
  }
}
